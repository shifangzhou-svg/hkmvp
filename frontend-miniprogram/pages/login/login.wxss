.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.logo {
  margin-bottom: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6700;
}

.form {
  width: 100%;
  max-width: 600rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.input-group input {
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
}

.code-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  color: #ff6700;
  background-color: transparent;
  border: 1rpx solid #ff6700;
  border-radius: 4rpx;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  color: white;
  background-color: #ff6700;
  border-radius: 8rpx;
  margin-top: 40rpx;
}

.tips {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: #999;
}

.link {
  color: #ff6700;
}
