.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.location-info {
  padding: 20rpx;
}

.location-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.dot.start {
  background-color: #4caf50;
}

.dot.end {
  background-color: #ff6700;
}

.arrow {
  text-align: center;
  color: #999;
  font-size: 32rpx;
  margin: 10rpx 0;
}

.location-text {
  font-size: 32rpx;
  color: #333;
}

.map-container {
  flex: 1;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.route-info {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.value {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

.value.price {
  color: #ff6700;
}

.action-bar {
  display: flex;
  padding: 30rpx;
  background-color: #fff;
  gap: 20rpx;
}

.back-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  color: #666;
  background-color: #f0f0f0;
  border-radius: 45rpx;
}

.confirm-btn {
  flex: 2;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  color: #fff;
  background-color: #ff6700;
  border-radius: 45rpx;
}
