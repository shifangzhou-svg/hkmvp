.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #eee;
}

.search-input-container {
  flex: 1;
  display: flex;
  align-items: center;
  height: 60rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.search-icon {
  margin-right: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.search-input-container input {
  flex: 1;
  height: 100%;
  border: none;
  background: transparent;
  font-size: 28rpx;
}

.clear-icon {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #999;
  padding: 5rpx;
}

.search-bar button {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #ff6700;
  background-color: transparent;
  border: none;
}

/* 快捷选项 */
.quick-options {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #eee;
}

.quick-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.option-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.quick-option text {
  font-size: 24rpx;
  color: #666;
}

/* 搜索结果 */
.search-results {
  flex: 1;
  overflow-y: auto;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  background-color: #f5f5f5;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #eee;
}

.item-content {
  flex: 1;
  margin-right: 20rpx;
}

.item-name {
  display: block;
  font-size: 28rpx;
  margin-bottom: 5rpx;
  color: #333;
}

.item-address {
  display: block;
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-distance {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

/* 无结果 */
.no-results {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  background-color: white;
  margin: 20rpx;
  border-radius: 10rpx;
}