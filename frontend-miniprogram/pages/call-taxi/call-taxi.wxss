.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.map-container {
  flex: 1;
  position: relative;
}

.call-form {
  background-color: white;
  padding: 20rpx;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.location-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.location-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 10rpx;
}

.location-icon.start {
  background-color: #4caf50;
}

.location-icon.end {
  background-color: #ff6700;
}

.location-input {
  flex: 1;
}

.location-input input {
  font-size: 32rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eee;
  width: 100%;
}

.call-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  color: white;
  background-color: #ff6700;
  border-radius: 8rpx;
  margin-top: 20rpx;
}
